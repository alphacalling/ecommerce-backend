# Server Configuration
NODE_ENV=production
PORT=5000

# Database
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname
DATABASE_NAME=shopping

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=604800  # 7 days in seconds

# Cookie Configuration  
COOKIE_SECRET=your-super-secret-cookie-key-change-this-in-production

# Email Service
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# OTP Configuration
OTP_EXPIRY=300  # 5 minutes in seconds

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# CORS Configuration
CLIENT_URL=https://yourdomain.com
ADMIN_URL=https://admin.yourdomain.com

# Admin Bootstrap
ADMIN_EMAIL=admin@yourdomain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=600000
RATE_LIMIT_MAX_REQUESTS=150

# Logging
LOG_LEVEL=info

# Session
MAX_SESSIONS_PER_USER=5
SESSION_CLEANUP_INTERVAL=86400000  # 24 hours in milliseconds
